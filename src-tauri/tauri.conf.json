{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DesktopCal Lightweight",
  "version": "0.1.1",
  "identifier": "com.lcy.desktopcal.lightweight",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DesktopCal Lightweight",
        "width": 1300,
        "height": 850,
        "minWidth": 320,
        "minHeight": 44,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
